# RCS Platform - Environment Variables Template
# Copy this file to .env and fill in your values

# =============================================================================
# ENVIRONMENT
# =============================================================================
ENVIRONMENT=dev  # dev, staging, prod
DEBUG=true

# =============================================================================
# DATABASE
# =============================================================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=rcs_platform_dev
DB_USER=postgres
DB_PASSWORD=your-secure-password-here

# =============================================================================
# RABBITMQ
# =============================================================================
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=your-rabbitmq-password

# =============================================================================
# REDIS
# =============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=  # Leave empty if no password

# =============================================================================
# SECURITY
# =============================================================================
SECRET_KEY=your-secret-key-minimum-32-characters-long
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# =============================================================================
# RCS AGGREGATOR CONFIGURATION (rcssms.in)
# =============================================================================
RCS_USERNAME=your-rcssms-username
RCS_PASSWORD=your-rcssms-password
RCS_ID=your-rcs-bot-id
RCS_CLIENT_SECRET=your-client-secret  # For bearer token auth
RCS_USE_BEARER=true  # Use bearer token instead of password auth
RCS_TIMEOUT=30  # HTTP timeout in seconds

# =============================================================================
# SMS FALLBACK CONFIGURATION (smsidea.co.in)
# =============================================================================
SMS_USERNAME=your-smsidea-username
SMS_PASSWORD=your-smsidea-password-or-api-key
SMS_SENDER_ID=MYBRND  # 6-character DLT-approved sender ID
SMS_PEID=1234567890  # Principal Entity ID from DLT portal
SMS_TIMEOUT=30  # HTTP timeout in seconds

# =============================================================================
# OBSERVABILITY
# =============================================================================
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FORMAT=json  # json or text
METRICS_PORT=9090
JAEGER_ENDPOINT=http://localhost:14268/api/traces

# =============================================================================
# RATE LIMITING
# =============================================================================
RATE_LIMIT_ENABLED=true
DEFAULT_RATE_LIMIT=100  # requests per minute
AGGREGATOR_RATE_LIMIT=1000  # messages per second

# =============================================================================
# RETRY & FALLBACK
# =============================================================================
MAX_RETRIES=3
RETRY_BACKOFF=60  # seconds
ENABLE_FALLBACK=true
FALLBACK_DELAY=300  # seconds (5 minutes)

# =============================================================================
# API CONFIGURATION
# =============================================================================
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# =============================================================================
# AGGREGATOR URL OVERRIDES (Optional - for testing or custom deployments)
# =============================================================================
# Override RCS API endpoints (defaults to production rcssms.in URLs)
# RCS_SEND_URL=https://web.rcssms.in/rcsapi/jsonapi.jsp?apitype=1
# RCS_TOKEN_URL=https://web.rcssms.in/api/rcs/accesstoken
# RCS_TEMPLATE_URL=https://web.rcssms.in/rcsapi/rcscreatetemplate.jsp

# Override SMS API endpoints (defaults to production smsidea.co.in URLs)
# SMS_SEND_URL=https://smsidea.co.in/smsstatuswithid.aspx
# SMS_BALANCE_URL=https://smsidea.co.in/sms/api/getbalance.aspx

# =============================================================================
# TESTING
# =============================================================================
# Set to true to use mock adapter instead of real aggregators
# USE_MOCK_AGGREGATOR=false
